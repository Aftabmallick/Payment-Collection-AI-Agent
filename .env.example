# Required: OpenAI API key for GPT-4o structured extraction
OPENAI_API_KEY=your_openai_api_key_here

# Optional: MongoDB connection string (falls back to in-memory if unavailable)
MONGO_URI=mongodb://localhost:27017/

# Optional: Override defaults
# LLM_MODEL=gpt-4o
# LLM_TEMPERATURE=0
# LLM_TIMEOUT=30
# LLM_MAX_RETRIES=2
# API_TIMEOUT_SECONDS=15
# API_MAX_RETRIES=3
# MAX_VERIFICATION_RETRIES=3
# MAX_PAYMENT_RETRIES=3
# MAX_INPUT_LENGTH=500
